<!DOCTYPE html>
<html lang="zh">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>墨客·管理后台</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-stone-50 p-4 md:p-6 font-sans">
    <div class="max-w-7xl mx-auto">
        <div class="flex justify-between items-center mb-6">
            <h1 class="text-2xl font-light text-stone-700">📋 订单管理后台</h1>
            <div>
                <a href=" " class="bg-emerald-500 text-white px-4 py-2 rounded-lg text-sm hover:bg-emerald-600 transition">导出 CSV</a >
                <button onclick="location.reload()" class="ml-2 bg-stone-200 text-stone-700 px-4 py-2 rounded-lg text-sm hover:bg-stone-300">刷新</button>
            </div>
        </div>

        <!-- 订单表格 -->
        <div class="bg-white rounded-2xl shadow-md overflow-x-auto">
            <table class="w-full text-sm text-left">
                <thead class="bg-stone-100 text-stone-600 uppercase text-xs">
                    <tr>
                        <th class="px-4 py-3">ID</th>
                        <th class="px-4 py-3">客户</th>
                        <th class="px-4 py-3">风格</th>
                        <th class="px-4 py-3">字号</th>
                        <th class="px-4 py-3">纸张</th>
                        <th class="px-4 py-3">交期</th>
                        <th class="px-4 py-3">字数</th>
                        <th class="px-4 py-3">金额</th>
                        <th class="px-4 py-3">提交时间</th>
                        <th class="px-4 py-3">操作</th>
                    </tr>
                </thead>
                <tbody id="orderTableBody">
                    <tr><td colspan="10" class="text-center py-6 text-stone-400">加载中...</td></tr>
                </tbody>
            </table>
        </div>
    </div>

    <!-- 详情模态框 -->
    <div id="detailModal" class="fixed inset-0 z-50 flex items-center justify-center p-4 hidden backdrop-blur-sm bg-black/20">
        <div class="bg-white rounded-3xl shadow-2xl max-w-2xl w-full max-h-[80vh] overflow-y-auto p-6">
            <h3 class="text-xl font-medium mb-4">订单详情</h3>
            <div id="detailContent"></div>
            <button onclick="document.getElementById('detailModal').classList.add('hidden')" class="mt-4 w-full py-2 bg-stone-100 rounded-xl">关闭</button>
        </div>
    </div>

    <script>
        async function loadOrders() {
            const res = await fetch('/api/orders');
            const orders = await res.json();
            const tbody = document.getElementById('orderTableBody');
            if (orders.length === 0) {
                tbody.innerHTML = '<tr><td colspan="10" class="text-center py-6 text-stone-400">暂无订单</td></tr>';
                return;
            }
            tbody.innerHTML = orders.map(o => `
                <tr class="border-t hover:bg-stone-50">
                    <td class="px-4 py-3">${o.id}</td>
                    <td class="px-4 py-3 font-medium">${o.customer_name}</td>
                    <td class="px-4 py-3">${o.style || '-'}</td>
                    <td class="px-4 py-3">${o.size || '-'}</td>
                    <td class="px-4 py-3">${o.paper_type || '-'}</td>
                    <td class="px-4 py-3">${o.deadline}</td>
                    <td class="px-4 py-3">${o.word_count}</td>
                    <td class="px-4 py-3">¥${o.amount}</td>
                    <td class="px-4 py-3">${new Date(o.created_at).toLocaleString()}</td>
                    <td class="px-4 py-3">
                        <button onclick="viewDetail(${o.id})" class="text-emerald-600 hover:underline">查看</button>
                    </td>
                </tr>
            `).join('');
        }

        async function viewDetail(id) {
            const res = await fetch(`/api/order/${id}`);
            const data = await res.json();
            const content = `
                <p><strong>客户姓名：</strong>${data.customer_name}</p >
                <p><strong>风格：</strong>${data.style} / <strong>字号：</strong>${data.size}</p >
                <p><strong>纸张：</strong>${data.paper_type} / <strong>张数：</strong>${data.paper_count || '未指定'}</p >
                <p><strong>交期：</strong>${data.deadline}</p >
                <p><strong>字数：</strong>${data.word_count} 字 / <strong>金额：</strong>¥${data.amount}</p >
                <p class="mt-3"><strong>书写内容：</strong></p >
                <div class="bg-stone-50 p-3 rounded-lg max-h-60 overflow-y-auto whitespace-pre-wrap text-sm">${data.text_content}</div>
                <p class="mt-3 text-stone-400 text-xs">提交时间：${data.created_at}</p >
            `;
            document.getElementById('detailContent').innerHTML = content;
            document.getElementById('detailModal').classList.remove('hidden');
        }

        loadOrders();
    </script>
</body>
</html>